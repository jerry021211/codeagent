# Required: Anthropic-compatible model identifier.
MODEL_ID=deepseek-v4-pro

# Required when using a hosted model API.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: custom Anthropic-compatible endpoint.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional runtime settings.
MAX_TOKENS=8000
MAX_ITERATIONS=50
STREAMING=true
SYSTEM_PROMPT=You are a coding agent. Use tools to solve tasks.

# Optional runtime system prompt assembly settings.
PROMPT_TEMPLATE_DIR=.prompts
SYSTEM_PROMPT_BUDGET_CHARS=120000
SYSTEM_PROMPT_STATIC_BUDGET_CHARS=50000
SYSTEM_PROMPT_DYNAMIC_BUDGET_CHARS=70000
SKILL_CATALOG_BUDGET_CHARS=12000
CONTEXT_SUMMARY_BUDGET_CHARS=12000
PROMPT_TRACE=false

# Optional LangSmith tracing settings.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=CodeAgent
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Optional: max characters per traced string field before local truncation.
LANGSMITH_TRACE_MAX_STRING_CHARS=20000

# Optional skill loading settings.
ENABLE_SKILLS=true
SKILLS_DIR=.skills

# Optional long-term memory settings.
ENABLE_MEMORY=true
MEMORY_DIR=.memory
MEMORY_MAX_ITEMS_IN_PROMPT=50
MEMORY_MAX_LOADED_ITEMS=5
MEMORY_SESSION_BUDGET_CHARS=60000
MEMORY_MAX_MEMORY_BYTES=50000
MEMORY_SELECTION_MODE=llm
MEMORY_AUTO_EXTRACT=false
MEMORY_EXTRACT_RECENT_MESSAGES=12
MEMORY_CONSOLIDATE_THRESHOLD=30
MEMORY_CONSOLIDATE_MODE=simple
MEMORY_ALLOW_SUBAGENT_WRITE=false

# Optional context compaction settings.
CONTEXT_COMPACT_MODE=simple
CONTEXT_MAX_MESSAGES=50
CONTEXT_KEEP_HEAD_MESSAGES=3
CONTEXT_KEEP_TAIL_MESSAGES=47
CONTEXT_KEEP_RECENT_TOOL_RESULTS=3
CONTEXT_TOOL_RESULT_BUDGET_CHARS=200000
CONTEXT_SINGLE_TOOL_OUTPUT_MAX_CHARS=80000
CONTEXT_COMPACT_THRESHOLD_CHARS=300000
CONTEXT_SUMMARY_MAX_CHARS=12000
CONTEXT_TRANSCRIPT_DIR=.transcripts
CONTEXT_TOOL_OUTPUT_DIR=.task_outputs/tool-results
CONTEXT_REACTIVE_RETRIES=1
CONTEXT_MAX_COMPACT_FAILURES=3
